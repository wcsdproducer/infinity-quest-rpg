
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
        // Check if the user's custom claim 'isAdmin' is true
        // return request.auth.token.isAdmin == true;
        // As a temporary measure, check a field in the user's profile document
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    match /users/{userId} {
      // Users can only read and write to their own profile
      allow read, write: if isOwner(userId);
    }
    
    match /campaigns/{campaignId} {
        // Anyone can read campaigns
        allow read: if request.auth != null;
        // Only admins can create, update, or delete campaigns
        allow write: if isAdmin();
    }
    
    match /games/{gameId} {
        allow read, write: if request.auth != null;
    }

    match /games/{gameId}/characters/{characterId} {
        // Characters are written by Next.js server actions (no auth context)
        allow read, write: if true;
    }

    // ── Memory system subcollections ────────────────────────────────────────

    match /games/{gameId}/messages/{msgId} {
        // Server actions use the client SDK without auth — must be open
        allow read, write: if true;
    }

    match /games/{gameId}/state/{docId} {
        allow read, write: if true;
    }

    match /games/{gameId}/sessions/{sessionId} {
        allow read, write: if true;
    }

    match /games/{gameId}/memories/{memId} {
        allow read, write: if true;
    }

    // ── Comm channels ───────────────────────────────────────────────────────

    match /games/{gameId}/comms/{commId} {
        // Players can only read comms they're a participant in
        allow read: if request.auth != null && request.auth.uid in resource.data.participants;
        // Players can create comms where they are the sender and a participant
        allow create: if request.auth != null
            && request.auth.uid == request.resource.data.fromPlayerId
            && request.auth.uid in request.resource.data.participants;
        // No edits or deletes
        allow update, delete: if false;
    }

    match /app-settings/{settingsId} {
        // Anyone can read app settings
        allow read: if true;
        // Only admins can write to app settings
        allow write: if isAdmin();
    }
  }
}

service firebase.storage {
  match /b/{bucket}/o {
    // Allow all reads to all files
    allow read;
    // Allow writes only if the user is an admin
    match /{allPaths=**} {
      allow write: if request.auth != null && get(/databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
  }
}
