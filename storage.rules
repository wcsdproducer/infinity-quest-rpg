rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Campaign media (images, audio, video) — public read, auth write only
    match /campaigns/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // All other paths — authenticated users only
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
